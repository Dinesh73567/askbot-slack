# ===========================================
# AskBot Slack - Environment Variables
# ===========================================
# Copy this file to .env and fill in values
# cp .env.example .env

# --- Slack Bot Token (xoxb-) ---
# Get from: Slack App > OAuth & Permissions > Bot User OAuth Token
# Required scopes: app_mentions:read, chat:write, commands, users:read,
#   channels:history, groups:history, channels:read, groups:read, im:history
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# --- Slack App Token (xapp-) ---
# Get from: Slack App > Basic Information > App-Level Tokens
# Required scope: connections:write (for Socket Mode)
SLACK_APP_TOKEN=xapp-your-app-token-here

# --- Slack Signing Secret ---
# Get from: Slack App > Basic Information > App Credentials
SLACK_SIGNING_SECRET=your-signing-secret-here

# --- Anthropic API Key ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Claude Model (optional, defaults to claude-sonnet-4-20250514) ---
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Log Level (optional, defaults to info) ---
LOG_LEVEL=info

# --- Rate Limit (optional, defaults to 5 requests/user/minute) ---
RATE_LIMIT_PER_USER_PER_MINUTE=5
