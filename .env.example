# ===========================================
# AskBot Slack - Environment Variables
# ===========================================
# For local dev: cp .env.local .env
# For production: set these in Railway dashboard

NODE_ENV=development

# --- Database ---
# PostgreSQL required (local: Docker, prod: Railway)
# Local: postgresql://postgres:dev@localhost:5432/askbot
# Prod: Railway auto-provides DATABASE_URL via the Postgres addon reference
DATABASE_URL=postgresql://postgres:dev@localhost:5432/askbot

# --- Token encryption key (REQUIRED) ---
# 32-byte key as hex (64 chars). Generate with: openssl rand -hex 32
# Used to encrypt xoxp- user tokens at rest with AES-256-GCM
TOKEN_ENCRYPTION_KEY=

# --- App URL ---
# Local: http://localhost:3000
# Prod: https://your-app.up.railway.app
APP_URL=http://localhost:3000
PORT=3000

# --- Slack Bot Token (xoxb-) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# --- Slack App Token (xapp-) ---
SLACK_APP_TOKEN=xapp-your-app-token-here

# --- Slack Signing Secret ---
SLACK_SIGNING_SECRET=your-signing-secret-here

# --- Slack OAuth (for per-user authorization) ---
# Get from: Slack App > Basic Information > App Credentials
SLACK_CLIENT_ID=your-client-id-here
SLACK_CLIENT_SECRET=your-client-secret-here

# --- Anthropic API Key ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Claude Model ---
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- App Settings ---
LOG_LEVEL=info
RATE_LIMIT_PER_USER_PER_MINUTE=5
