# ===========================================
# AskBot Slack - PRODUCTION Config (Railway)
# ===========================================
# These are set in Railway dashboard, NOT in a file.
# This file is a reference only — do NOT commit real values.

NODE_ENV=production

# --- Database (Railway provides this automatically) ---
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://... (auto-provided by Railway PostgreSQL addon)

# --- App URL (Railway provides this) ---
APP_URL=https://your-app.up.railway.app
PORT=3000

# --- Slack Tokens (set in Railway Variables tab) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# --- Slack OAuth ---
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- App Settings ---
LOG_LEVEL=info
RATE_LIMIT_PER_USER_PER_MINUTE=5
