generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserToken {
  id        String   @id @default(uuid())
  userId    String   @unique
  token     String
  teamId    String
  scopes    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
