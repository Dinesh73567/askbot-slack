// Uses PostgreSQL for both local dev and production.
// Local: run Postgres via Docker (see README) and set DATABASE_URL accordingly.
// Production: Railway Postgres addon auto-provides DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserToken {
  id        String   @id @default(uuid())
  userId    String   @unique
  token     String
  teamId    String
  scopes    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
